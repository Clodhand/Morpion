from ia_morpion import ia_aleatoire, joueur_humain


# Test des conditions de Victoire
def condition_victoire(ma_grille) :
# Test de ligne gagnante
    for ligne in ma_grille:
        if ligne[0] == ligne[1] == ligne[2] != " ":
            return True, ligne[0], False # Victoire ligne
# Test de colonne gagnante
    for col in range(3):
        if ma_grille[0][col] == ma_grille[1][col] == ma_grille[2][col] != " ":
            return True, ma_grille[0][col], False # Victoire colonne
# Test des diagonales gagnantes
    if (ma_grille[0][0] == ma_grille[1][1] == ma_grille[2][2] != " ") or \
        (ma_grille[2][0] == ma_grille[1][1] == ma_grille[0][2] != " "):
            return True, ma_grille[1][1], False # Victoire diagonale
# Pas de victoire  - Vérification match nul
    if sum(row.count(" ") for row in ma_grille) == 0:
        return False, None, True # Nul
    return False, None, False # En cours

# Affichage de la grille
def affichage_grille(ma_grille):
    for row in ma_grille:
        print(" | ".join(row))
        print("-" * 9)

def jouer_partie(nb_parties, joueur1_func, joueur2_func, symbole1="x", symbole2="o"):
    # Compteur à zero
    victoire_joueur1 = 0
    victoire_joueur2 = 0
    parties_nuls = 0
    # Boucle du nombre de partie
    for i in range(nb_parties):
        print(f"Partie {i + 1}")
        # Création de la grille
        grille = [[" " for i in range(3)] for t in range(3)]
        # Boucle tour de jeu
        for tour in range(9):
            # Déterminer le joueur courant
            if tour % 2 == 0:
                joueur_courant = joueur1_func
                symbole = symbole1
            else:
                joueur_courant = joueur2_func
                symbole = symbole2
            # Afficher la grille avant le coup si le joueur est humain
            if joueur_courant == joueur_humain:
                affichage_grille(grille)
            # Obtenir le coup
            coor = joueur_courant(grille, symbole)
            grille[coor[0]][coor[1]] = symbole
            # Afficher la grille après chaque coup
            affichage_grille(grille)
            est_gagne, joueur, est_nul = condition_victoire(grille)
            print(f"Tour {tour}, est_gagne={est_gagne}, joueur={joueur}, est_nul={est_nul}")
            if est_gagne:
                if joueur == symbole1:
                    victoire_joueur1 += 1
                    print(f"victoire joueur1 ({symbole1}) {victoire_joueur1}")
                else:
                    victoire_joueur2 += 1
                    print(f"victoire joueur2 ({symbole2}) {victoire_joueur2}")
                break
            elif est_nul:
                parties_nuls += 1
                print(f"Match nul détecté !!! parties nuls= {parties_nuls}")
                print("grille final : ")
                affichage_grille(grille)
                break
            print(f"Fin de partie {i + 1}: victoire_joueur1={victoire_joueur1}, victoire_joueur2={victoire_joueur2}, parties_nuls={parties_nuls}")
        print("\nRésultats finaux :")
        print(f"Victoires Joueur1 ({symbole1}): {victoire_joueur1}")
        print(f"Victoires Joueur2 ({symbole2}): {victoire_joueur2}")
        print(f"Matchs nuls : {parties_nuls}")
    return victoire_joueur1, victoire_joueur2, parties_nuls











